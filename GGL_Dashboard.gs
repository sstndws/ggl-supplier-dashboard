function getFieldMeta_(key) {
  for (var i = 0; i < MASTER_FIELDS.length; i++) {
    if (MASTER_FIELDS[i].key === key) return MASTER_FIELDS[i];
  }
  return { key: key, label: key, type: 'text', width: 140 };
}

